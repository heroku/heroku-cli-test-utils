{
  "name": "@heroku-cli/test-utils",
  "version": "0.1.2",
  "description": "Test utilities for Heroku CLI",
  "author": "Heroku",
  "license": "ISC",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/heroku/heroku-cli-test-utils"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./eslint-config": {
      "types": "./dist/eslint-config.d.ts",
      "default": "./dist/eslint-config.js"
    }
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/chai": "^4.3.13",
    "@types/eslint": "^9.6.1",
    "@types/mocha": "^10.0.6",
    "@types/node": "^22.15.3",
    "@types/sinon": "^17.0.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-mocha": "^11.2.0",
    "mocha": "^11.3.0",
    "nyc": "^17.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "chai": "^4.4.1",
    "eslint": "^8.57.0 || ^9",
    "eslint-config-oclif": "^6.0.148",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-mocha": "^11.2.0",
    "nock": "^13.2.9",
    "sinon": "^18.0.1"
  },
  "dependencies": {
    "@heroku-cli/command": "^12.2.0",
    "@heroku/heroku-cli-util": "^10.6.0",
    "@oclif/core": "^4.8.4",
    "ansis": "^4",
    "stdout-stderr": "^0.1.13"
  },
  "mocha": {
    "loader": "ts-node/esm",
    "extensions": [
      "ts"
    ],
    "watch-extensions": "ts",
    "recursive": true,
    "reporter": "spec",
    "timeout": 360000
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run clean && tsc",
    "clean": "rm -rf dist",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "prepare": "npm run build",
    "test": "nyc mocha  --forbid-only \"test/**/*.test.ts\""
  }
}
