{
  "name": "@heroku-cli/test-utils",
  "version": "0.3.0",
  "description": "Test utilities for Heroku CLI",
  "author": "Heroku",
  "license": "ISC",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/heroku/heroku-cli-test-utils"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./eslint-config": {
      "types": "./dist/eslint-config/index.d.ts",
      "default": "./dist/eslint-config/index.js"
    },
    "./eslint-config/mocha": {
      "types": "./dist/eslint-config/mocha.d.ts",
      "default": "./dist/eslint-config/mocha.js"
    },
    "./eslint-config/vitest": {
      "types": "./dist/eslint-config/vitest.d.ts",
      "default": "./dist/eslint-config/vitest.js"
    }
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "^4.0.0",
    "@vitest/eslint-plugin": "^1.6.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  },
  "peerDependencies": {
    "@vitest/eslint-plugin": ">=1.6",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "nock": ">=14"
  },
  "peerDependenciesMeta": {
    "@vitest/eslint-plugin": {
      "optional": true
    }
  },
  "dependencies": {
    "@heroku-cli/command": "^12",
    "@oclif/core": "^4",
    "ansis": "^4"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run clean && tsc",
    "clean": "rm -rf dist",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  }
}
