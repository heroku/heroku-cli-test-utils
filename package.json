{
  "name": "@heroku-cli/test-utils",
  "version": "0.2.0",
  "description": "Test utilities for Heroku CLI",
  "author": "Heroku",
  "license": "ISC",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/heroku/heroku-cli-test-utils"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./eslint-config": {
      "types": "./dist/eslint-config.d.ts",
      "default": "./dist/eslint-config.js"
    }
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/eslint": "^9.6.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.15.3",
    "@types/sinon": "^17.0.4",
    "c8": "^10.1.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-mocha": "^11.2.0",
    "mocha": "^11.7.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "chai": ">=5",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-plugin-import": "^2",
    "eslint-plugin-mocha": "^11",
    "nock": ">=14",
    "sinon": ">=20"
  },
  "dependencies": {
    "@heroku-cli/command": "^12",
    "@oclif/core": "^4",
    "ansis": "^4"
  },
  "mocha": {
    "loader": "ts-node/esm",
    "extensions": [
      "ts"
    ],
    "watch-extensions": "ts",
    "recursive": true,
    "reporter": "spec",
    "timeout": 360000
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run clean && tsc",
    "clean": "rm -rf dist",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prepare": "npm run build",
    "test": "c8 --check-coverage mocha --forbid-only \"test/**/*.test.ts\""
  }
}
